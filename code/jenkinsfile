pipeline{
    agent any
    environment{
        IMAGE_NAME = "niranjansc/devops:${GIT_COMMIT}"
    }
    stages{
        stage('Git-Checkout'){
            steps{
                git url: 'https://github.com/niranjansc/devops.git',branch:'main'
            }
        }
        stage('Build'){
            steps{
                sh '''
                   printenv
                   pwd
                   cd code/ 
                   docker build -t ${IMAGE_NAME} .
                '''
            }
        }
    }
}