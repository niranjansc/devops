pipeline{
    agent any
    environment{
        IMAGE_NAME = "niranjansc/devops:${GIT_COMMIT}"
    }
    stages{
        stage('Git-Checkout'){
            steps{
                git url: 'https://github.com/niranjansc/devops.git',branch:'main'
            }
        }
        stage('Build'){
            steps{
                sh '''
                   printenv
                   pwd
                   cd code/ 
                   docker build -t ${IMAGE_NAME} .
                '''
            }
        }

        // stage('testing the image'){
        //     steps{
        //         sh'''
        //              docker run -it -d --name c1 -p 9001:8501 ${IMAGE_NAME} 
        //         '''
        //     }
        // }

            stage('dockerhub'){
                steps{
                    withCredentials([usernamePassword(credentialsId: 'dockerhub', passwordVariable: '    ', usernameVariable: 'DOCKER_USERNAME')]) {
                         sh 'echo $DOCKER_PASSWORD | docker login -u $DOCKER_USERNAME --password-stdin'
                   }
                }
            }

            stage('pushing to Registry'){
                steps{
                    sh '''
                         docker push ${IMAGE_NAME} 
                    '''
                }
            }
    }
}